# Database
DATABASE_URL=postgresql://localhost:5432/servicing_mini_dev

# LLM Provider: "stub" (default, no API key needed) | "anthropic" | "openai" | "gemini"
LLM_PROVIDER=stub

# Required only when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-xxx

# Required only when LLM_PROVIDER=openai
OPENAI_API_KEY=sk-xxx

# Required only when LLM_PROVIDER=gemini (free tier works); model optional
GEMINI_API_KEY=AIza-xxx
# GEMINI_MODEL=gemini-3.1-flash-lite
